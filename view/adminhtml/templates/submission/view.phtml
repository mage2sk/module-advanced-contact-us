<div class="panth-submission-view">
    <div class="panth-sv-header">
        <div class="panth-sv-title">Submission #<?= (int) $submission->getId() ?></div>
        <span class="panth-sv-badge" style="background: <?= $escaper->escapeHtmlAttr($statusColors[$status] ?? '#9CA3AF') ?>">
            <?= $escaper->escapeHtml($statusLabels[$status] ?? 'Unknown') ?>
        </span>
    </div>

    <div class="panth-sv-card">
        <div class="panth-sv-row">
            <div class="panth-sv-label">Name</div>
            <div class="panth-sv-value"><?= $block->escapeHtml($submission->getData('name')) ?></div>
        </div>
        <div class="panth-sv-row">
            <div class="panth-sv-label">Email</div>
            <div class="panth-sv-value">
                <a href="mailto:<?= $block->escapeHtmlAttr($submission->getData('email')) ?>">
                    <?= $block->escapeHtml($submission->getData('email')) ?>
                </a>
            </div>
        </div>
        <?php if ($submission->getData('telephone')): ?>
        <div class="panth-sv-row">
            <div class="panth-sv-label">Phone</div>
            <div class="panth-sv-value"><?= $block->escapeHtml($submission->getData('telephone')) ?></div>
        </div>
        <?php endif; ?>
        <?php if ($submission->getData('subject')): ?>
        <div class="panth-sv-row">
            <div class="panth-sv-label">Subject</div>
            <div class="panth-sv-value"><?= $block->escapeHtml($submission->getData('subject')) ?></div>
        </div>
        <?php endif; ?>
        <div class="panth-sv-row">
            <div class="panth-sv-label">Message</div>
            <div class="panth-sv-value panth-sv-message"><?= $block->escapeHtml($submission->getData('message')) ?></div>
        </div>
        <?php
        $customFields = $submission->getData('custom_fields');
        if ($customFields):
            $fields = json_decode($customFields, true);
            if (is_array($fields)):
                foreach ($fields as $label => $value): ?>
        <div class="panth-sv-row">
            <div class="panth-sv-label"><?= $block->escapeHtml($label) ?></div>
            <div class="panth-sv-value"><?= $block->escapeHtml(is_array($value) ? implode(', ', $value) : $value) ?></div>
        </div>
        <?php endforeach; endif; endif; ?>
    </div>

    <div class="panth-sv-card" style="background: #F9FAFB;">
        <div class="panth-sv-row">
            <div class="panth-sv-label">IP Address</div>
            <div class="panth-sv-value"><?= $block->escapeHtml($submission->getData('ip_address') ?: 'N/A') ?></div>
        </div>
        <div class="panth-sv-row">
            <div class="panth-sv-label">Submitted</div>
            <div class="panth-sv-value"><?= $block->escapeHtml($submission->getData('created_at')) ?></div>
        </div>
        <div class="panth-sv-row">
            <div class="panth-sv-label">Store</div>
            <div class="panth-sv-value">Store #<?= (int) $submission->getData('store_id') ?></div>
        </div>
    </div>

    <div class="panth-sv-actions">
        <a href="<?= $block->escapeUrl($block->getUrl('panthcontact/submission/index')) ?>" class="panth-sv-btn panth-sv-btn-back">
            &larr; Back to List
        </a>
        <a href="mailto:<?= $block->escapeHtmlAttr($submission->getData('email')) ?>?subject=Re: <?= $block->escapeHtmlAttr($submission->getData('subject') ?: 'Your inquiry') ?>" class="panth-sv-btn panth-sv-btn-reply">
            Reply via Email
        </a>
        <a href="<?= $block->escapeUrl($block->getUrl('panthcontact/submission/delete', ['id' => $submission->getId()])) ?>"
           class="panth-sv-btn panth-sv-btn-delete"
           onclick="return confirm('Are you sure you want to delete this submission?')">
            Delete
        </a>
    </div>
</div>
