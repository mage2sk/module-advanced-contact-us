<?php
/** @var \Magento\Backend\Block\Template $block */
/** @var \Panth\AdvancedContactUs\ViewModel\SubmissionView $viewModel */
$viewModel = $block->getViewModel();
$submission = $viewModel->getSubmission();

if (!$submission) {
    return;
}

$statusLabels = $viewModel->getStatusLabels();
$statusColors = $viewModel->getStatusColors();
$status = (int) $submission->getData('status');
?>

<style>
