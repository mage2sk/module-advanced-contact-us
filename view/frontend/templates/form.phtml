<script>
document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('<?= $escaper->escapeJs($formId) ?>');
    var successEl = document.getElementById('<?= $escaper->escapeJs($successId) ?>');
    var formCard = document.getElementById('<?= $escaper->escapeJs($formCardId) ?>');
    var errorEl = document.getElementById('<?= $escaper->escapeJs($errorId) ?>');
    var submitBtn = document.getElementById('panth-contact-submit');

    if (!form) return;

    function showError(field) {
        var el = document.querySelector('[data-error-for="' + field + '"]');
        var input = form.querySelector('[name="' + field + '"]');
        if (el) el.style.display = 'block';
        if (input) {
            input.classList.add('panth-cf-input-error');
            input.classList.remove('panth-cf-input-valid');
        }
    }

    function hideError(field) {
        var el = document.querySelector('[data-error-for="' + field + '"]');
        var input = form.querySelector('[name="' + field + '"]');
        if (el) el.style.display = 'none';
        if (input) {
            input.classList.remove('panth-cf-input-error');
            input.classList.add('panth-cf-input-valid');
        }
    }

    function clearErrors() {
        var errors = form.querySelectorAll('.panth-cf-field-error');
        for (var i = 0; i < errors.length; i++) errors[i].style.display = 'none';
        var inputs = form.querySelectorAll('.panth-cf-input-error');
        for (var i = 0; i < inputs.length; i++) inputs[i].classList.remove('panth-cf-input-error');
        errorEl.style.display = 'none';
    }

    function validate() {
        var valid = true;
        clearErrors();

        var name = form.querySelector('[name="name"]');
        if (!name || !name.value.trim()) { showError('name'); valid = false; }
        else { hideError('name'); }

        var email = form.querySelector('[name="email"]');
        if (!email || !email.value.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) { showError('email'); valid = false; }
        else { hideError('email'); }

        var message = form.querySelector('[name="message"]');
        if (!message || !message.value.trim()) { showError('message'); valid = false; }
        else { hideError('message'); }

        // Validate required custom/extra fields
        var requiredFields = form.querySelectorAll('[data-validate="required"]');
        for (var i = 0; i < requiredFields.length; i++) {
            var f = requiredFields[i];
            if (f.name === 'name' || f.name === 'email' || f.name === 'message') continue;
            if (!f.value || !f.value.trim()) { showError(f.name); valid = false; }
            else { hideError(f.name); }
        }

        return valid;
    }

    // Live validation on blur
    form.addEventListener('focusout', function(e) {
        var input = e.target;
        if (!input.name) return;
        if (input.dataset.validate === 'required' || input.name === 'name' || input.name === 'message') {
            if (!input.value.trim()) showError(input.name);
            else hideError(input.name);
        }
        if (input.name === 'email') {
            if (!input.value.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) showError('email');
            else hideError('email');
        }
    });

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        if (!validate()) return;

        submitBtn.disabled = true;
        submitBtn.querySelector('span').textContent = '<?= $escaper->escapeJs(__('Sending...')) ?>';
        errorEl.style.display = 'none';

        var formData = new FormData(form);
        formData.append('ajax', '1');

        var xhr = new XMLHttpRequest();
        xhr.open('POST', form.action, true);
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
        xhr.onload = function() {
            submitBtn.disabled = false;
            submitBtn.querySelector('span').textContent = '<?= $escaper->escapeJs(__('Send Message')) ?>';
            try {
                var data = JSON.parse(xhr.responseText);
                if (data.success) {
                    formCard.style.display = 'none';
                    successEl.style.display = 'block';
                } else {
                    errorEl.textContent = data.message || '<?= $escaper->escapeJs(__('An error occurred.')) ?>';
                    errorEl.style.display = 'block';
                }
            } catch (err) {
                errorEl.textContent = '<?= $escaper->escapeJs(__('Network error. Please try again.')) ?>';
                errorEl.style.display = 'block';
            }
        };
        xhr.onerror = function() {
            submitBtn.disabled = false;
            submitBtn.querySelector('span').textContent = '<?= $escaper->escapeJs(__('Send Message')) ?>';
            errorEl.textContent = '<?= $escaper->escapeJs(__('Network error. Please try again.')) ?>';
            errorEl.style.display = 'block';
        };
        xhr.send(formData);
    });
});
</script>
