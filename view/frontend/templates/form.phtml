<style>
/* Panth Contact Form */
.panth-contact { max-width: 1000px; margin: 0 auto; padding: 40px 20px; font-family: 'DM Sans', system-ui, sans-serif; }
.panth-contact-grid { display: grid; grid-template-columns: 1fr 340px; gap: 40px; }
.panth-contact-title { font-size: 32px; font-weight: 800; color: var(--contact-text, #171717); margin: 0 0 6px; }
.panth-contact-subtitle { font-size: 15px; color: var(--contact-text-muted, #6B7280); margin: 0 0 32px; }

/* Form Card */
.panth-cf-card { background: var(--contact-bg, #fff); border: 1px solid var(--contact-border, #E5E7EB); border-radius: var(--contact-radius, 12px); padding: 32px; }
.panth-cf-row { margin-bottom: 20px; }
.panth-cf-row-half { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.panth-cf-label { display: block; font-size: 13px; font-weight: 600; color: var(--contact-text, #171717); margin-bottom: 6px; }
.panth-cf-label .panth-cf-required { color: var(--contact-error, #EF4444); }
.panth-cf-input { width: 100%; height: 46px; padding: 0 16px; border: 1.5px solid var(--contact-border, #E5E7EB); border-radius: 10px; font-size: 14px; color: var(--contact-text, #171717); background: var(--contact-input-bg, #F9FAFB); transition: border-color 0.15s, box-shadow 0.15s; outline: none; font-family: inherit; box-sizing: border-box; }
.panth-cf-input:focus { border-color: var(--contact-input-focus, #0D9488); background: #fff; box-shadow: 0 0 0 3px rgba(13,148,136,0.08); }
.panth-cf-textarea { width: 100%; min-height: 140px; padding: 14px 16px; border: 1.5px solid var(--contact-border, #E5E7EB); border-radius: 10px; font-size: 14px; color: var(--contact-text, #171717); background: var(--contact-input-bg, #F9FAFB); transition: border-color 0.15s; outline: none; resize: vertical; font-family: inherit; line-height: 1.6; box-sizing: border-box; }
.panth-cf-textarea:focus { border-color: var(--contact-input-focus, #0D9488); background: #fff; box-shadow: 0 0 0 3px rgba(13,148,136,0.08); }
.panth-cf-select { width: 100%; height: 46px; padding: 0 16px; border: 1.5px solid var(--contact-border, #E5E7EB); border-radius: 10px; font-size: 14px; color: var(--contact-text, #171717); background: var(--contact-input-bg, #F9FAFB); transition: border-color 0.15s; outline: none; font-family: inherit; cursor: pointer; appearance: auto; box-sizing: border-box; }
.panth-cf-select:focus { border-color: var(--contact-input-focus, #0D9488); }
.panth-cf-error { font-size: 12px; color: var(--contact-error, #EF4444); margin-top: 4px; display: none; }
.panth-cf-input-error, .panth-cf-input-error:focus { border-color: var(--contact-error, #EF4444) !important; box-shadow: 0 0 0 3px rgba(239,68,68,0.08) !important; }
.panth-cf-input-valid { border-color: var(--contact-success, #10B981) !important; }
.panth-cf-field-error { font-size: 12px; color: var(--contact-error, #EF4444); margin-top: 4px; display: none; }

/* Radio/Checkbox */
.panth-cf-choice { display: flex; align-items: center; gap: 8px; padding: 8px 0; font-size: 14px; color: var(--contact-text, #171717); cursor: pointer; }
.panth-cf-choice input[type="radio"],
.panth-cf-choice input[type="checkbox"] { accent-color: var(--contact-primary, #0D9488); width: 18px; height: 18px; cursor: pointer; }

/* Submit Button */
.panth-cf-submit { display: inline-flex; align-items: center; justify-content: center; gap: 8px; width: 100%; height: 50px; padding: 0 32px; background: var(--contact-primary, #0D9488) !important; color: #fff !important; border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; transition: background 0.2s, transform 0.1s; font-family: inherit; text-decoration: none; }
.panth-cf-submit span { color: #fff !important; }
.panth-cf-submit:hover { background: var(--contact-primary-hover, #0F766E) !important; color: #fff !important; }
.panth-cf-submit:active { transform: scale(0.98); }
.panth-cf-submit:disabled { opacity: 0.6; cursor: not-allowed; }

/* Info Card */
.panth-ci-card { background: var(--contact-card-bg, #F9FAFB); border: 1px solid var(--contact-border, #E5E7EB); border-radius: var(--contact-radius, 12px); padding: 28px; height: fit-content; position: sticky; top: 100px; }
.panth-ci-title { font-size: 18px; font-weight: 700; color: var(--contact-text, #171717); margin: 0 0 20px; }
.panth-ci-item { display: flex; gap: 14px; padding: 14px 0; border-bottom: 1px solid #E5E7EB; }
.panth-ci-item:last-child { border-bottom: none; }
.panth-ci-icon { width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: #F0FDFA; border-radius: 10px; color: var(--contact-primary, #0D9488); flex-shrink: 0; }
.panth-ci-text { flex: 1; }
.panth-ci-label { font-size: 12px; font-weight: 600; color: var(--contact-text-muted, #6B7280); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px; }
.panth-ci-value { font-size: 14px; color: var(--contact-text, #171717); }
.panth-ci-value a { color: var(--contact-primary, #0D9488); text-decoration: none; }
.panth-ci-value a:hover { text-decoration: underline; }

/* Success State */
.panth-cf-success { text-align: center; padding: 60px 20px; }
.panth-cf-success-icon { width: 64px; height: 64px; margin: 0 auto 20px; background: #D1FAE5; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.panth-cf-success-title { font-size: 22px; font-weight: 700; color: var(--contact-text, #171717); margin: 0 0 8px; }
.panth-cf-success-msg { font-size: 15px; color: var(--contact-text-muted, #6B7280); margin: 0; line-height: 1.6; max-width: 400px; margin: 0 auto; }

/* Alert */
.panth-cf-alert { padding: 12px 16px; border-radius: 10px; font-size: 14px; margin-bottom: 20px; display: none; }
.panth-cf-alert-error { background: #FEF2F2; color: #DC2626; border: 1px solid #FECACA; }

/* Honeypot */
.panth-cf-hp { position: absolute; left: -9999px; opacity: 0; height: 0; width: 0; overflow: hidden; }

/* Mobile */
@media (max-width: 768px) {
    .panth-contact { padding: 24px 16px; }
    .panth-contact-grid { grid-template-columns: 1fr; gap: 24px; }
    .panth-contact-title { font-size: 26px; }
    .panth-cf-card { padding: 24px 20px; }
    .panth-cf-row-half { grid-template-columns: 1fr; gap: 16px; }
    .panth-ci-card { position: static; }
}
</style>

